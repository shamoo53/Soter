generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum CampaignStatus {
  draft
  active
  paused
  completed
  archived
}

enum ClaimStatus {
  requested
  verified
  approved
  disbursed
  archived
}

model AidPackage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  status    String   @default("draft")
}

enum VerificationChannel {
  email
  phone
}

enum VerificationSessionStatus {
  pending
  completed
  expired
  failed
}

enum SessionType {
  otp_verification
  claim_verification
  multi_step_verification
}

enum SessionStepStatus {
  pending
  in_progress
  completed
  failed
  skipped
}

model VerificationSession {
  id          String                   @id @default(cuid())
  channel     VerificationChannel
  identifier  String
  code        String
  attempts    Int                      @default(0)
  resendCount Int                      @default(0)
  status      VerificationSessionStatus @default(pending)
  expiresAt   DateTime
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@index([identifier, createdAt])
  @@index([status, expiresAt])
}

model Session {
  id          String                   @id @default(cuid())
  type        SessionType
  status      VerificationSessionStatus @default(pending)
  contextId   String?
  metadata    Json?
  expiresAt   DateTime?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  completedAt DateTime?
  failedAt    DateTime?

  steps       SessionStep[]
  submissions SessionSubmission[]

  @@index([type, status])
  @@index([contextId])
  @@index([expiresAt])
  @@index([createdAt])
}

model SessionStep {
  id          String            @id @default(cuid())
  sessionId   String
  stepName    String
  stepOrder   Int
  status      SessionStepStatus @default(pending)
  input       Json?
  output      Json?
  error       String?
  attempts    Int               @default(0)
  maxAttempts Int               @default(3)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  session     Session           @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  submissions SessionSubmission[]

  @@index([sessionId, stepOrder])
  @@index([status])
  @@index([stepName])
}

model SessionSubmission {
  id            String    @id @default(cuid())
  sessionId     String
  stepId        String?
  submissionKey String    @unique
  payload       Json
  response      Json?
  createdAt     DateTime  @default(now())

  session       Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  step          SessionStep? @relation(fields: [stepId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([stepId])
}

model VerificationRequest {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  status    String   @default("pending")
}

model Claim {
  id           String      @id @default(cuid())
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?

  status       ClaimStatus @default(requested)

  campaignId   String
  campaign     Campaign    @relation(fields: [campaignId], references: [id])

  amount       Float

  recipientRef String
  evidenceRef  String?

  @@index([status])
  @@index([campaignId])
  @@index([createdAt])
  @@index([deletedAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String
  entity    String
  entityId  String
  action    String
  timestamp DateTime @default(now())
  metadata  Json?

  @@index([entity, entityId])
  @@index([timestamp])
}

model Campaign {
  id          String          @id @default(cuid())

  name        String

  status      CampaignStatus @default(draft)

  budget      Float

  metadata    Json?

  ngoId       String?

  archivedAt  DateTime?
  deletedAt   DateTime?

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  claims      Claim[]

  @@index([status])
  @@index([archivedAt])
  @@index([ngoId])
  @@index([deletedAt])
}

model Role {
  id   Int    @id @default(autoincrement())
  name String @unique
}

enum AppRole {
  admin
  operator
  client
  ngo
}

model ApiKey {
  id          String   @id @default(cuid())
  // `key` is a legacy plaintext column. New keys should use `keyHash` and
  // `keyPreview` and never store raw secrets.
  key         String?  @unique
  keyHash     String?  @unique
  keyPreview  String?
  role        AppRole
  ngoId       String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastUsedAt  DateTime?
  createdBy   String?
  revokedAt   DateTime?
  revokedBy   String?
  revokedReason String?
  replacedById String?
  replacedBy   ApiKey?  @relation("ApiKeyReplacement", fields: [replacedById], references: [id])
  replacedFrom ApiKey[] @relation("ApiKeyReplacement")

  @@index([ngoId])
  @@index([revokedAt])
  @@index([lastUsedAt])
}

model InternalNote {
  id          String   @id @default(cuid())
  entityType  String   // e.g., "claim", "verification"
  entityId    String
  content     String
  authorId    String
  category    String?  // optional category metadata
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([entityType, entityId])
  @@index([authorId])
}
